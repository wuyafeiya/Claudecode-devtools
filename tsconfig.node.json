{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["server/**/*.ts", "vite.config.ts", "scripts/**/*.mjs"]
}
